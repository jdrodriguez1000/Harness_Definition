{
  "permissions": {
    "allow": [
      "Write(*)",
      "Read(*)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(New-Item *)",
      "Bash(Test-Path *)",
      "Bash(Add-Content *)",
      "Bash(Get-Date*)",
