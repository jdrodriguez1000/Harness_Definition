{
  "permissions": {
    "allow": [
      "Write(*)",
      "Read(*)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(New-Item *)",
      "Bash(Test-Path *)",
      "Bash(Add-Content *)",
      "Bash(Get-Date*)",
      "Bash(Remove-Item *)",
      "Bash(powershell.exe *)",
      "PowerShell($env:HARNESS_DEPLOY_SCRIPT)",
      "Bash(claude --dangerously-skip-permissions -p *)"
    ]
  },
  ,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -WindowStyle Hidden -File \"C:\\Users\\USUARIO\\.claude\\ccnotify.ps1\" -Event Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -WindowStyle Hidden -File \"C:\\Users\\USUARIO\\.claude\\ccnotify.ps1\" -Event Notification"
          }
        ]
      }
    ]
  }  
}
